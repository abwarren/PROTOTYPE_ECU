  (text "MCU CORE, DEBUG & MEMORY — Sheet 02" (at 25 280 0) (effects (font (size 3.0 3.0) bold) (justify left bottom)))
  (text "NXP S32K344EHT1VPBST | HLQFP176 EP | ARM Cortex-M7 Lockstep @ 160 MHz" (at 25 274 0) (effects (font (size 1.5 1.5)) (justify left bottom)))
  (text "40 MHz crystal (NX5032GA) + 32.768 kHz RTC | Guard ring required, no traces under crystal" (at 220 110 0) (effects (font (size 1.27 1.27)) (justify left bottom)))
  (text "Decoupling: 4x 0.1uF + 10uF + 100uF Tant per VDD_HV bank | 2x 2.2uF per V15 pin" (at 470 135 0) (effects (font (size 1.27 1.27)) (justify left bottom)))
  (text "RESET: 10k pull-up to +3V3, 100nF to GND, push-button for dev" (at 260 115 0) (effects (font (size 1.27 1.27)) (justify left bottom)))
  (text "BOOT_CFG[1:0] = 00 (boot from internal P-Flash)" (at 260 80 0) (effects (font (size 1.27 1.27)) (justify left bottom)))
